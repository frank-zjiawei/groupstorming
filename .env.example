# All env vars must be prefixed with VITE_ so Vite exposes them to the browser.

# Required for Claude API calls (synthesis, evaluation, live brainstorm analysis).
# Create a key at https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY="MY_ANTHROPIC_API_KEY"

# Required for live speech transcription with speaker diarization.
# Create a key at https://console.deepgram.com — $200 free credit on signup.
VITE_DEEPGRAM_API_KEY="MY_DEEPGRAM_API_KEY"
